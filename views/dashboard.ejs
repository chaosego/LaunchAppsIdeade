<%- include('partials/head') %>

<% if (configErrors && configErrors.length) { %>
  <section class="banner banner-warn">
    <strong>Avisos de configuración (<%= configSource %>):</strong>
    <ul>
      <% configErrors.forEach(function (e) { %>
        <li><%= e %></li>
      <% }); %>
    </ul>
  </section>
<% } %>

<section class="toolbar">
  <div class="global-buttons">
    <button data-global="start-all">▶ Iniciar todas</button>
    <button data-global="stop-all">■ Parar todas</button>
    <button data-global="restart-all">↻ Reiniciar todas</button>
    <button data-global="refresh-all">⟳ Refrescar estado</button>
  </div>
  <span id="conn" class="conn conn-off" title="Conexión SSE">● desconectado</span>
</section>

<section class="apps">
  <% if (!apps.length) { %>
    <p class="empty">No hay apps configuradas. Editá <code>apps.json</code> (plantilla en <code>apps.example.json</code>).</p>
  <% } else { %>
    <table class="apps-table">
      <thead>
        <tr>
          <th>App</th>
          <th>Tipo</th>
          <th>Puerto</th>
          <th>Estado</th>
          <th>Latencia</th>
          <th>Autostart</th>
          <th>Watchdog</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% apps.forEach(function (app) { %>
          <tr data-app-id="<%= app.id %>">
            <td>
              <span class="app-name"><%= app.name %></span>
              <span class="app-id muted"><%= app.id %></span>
            </td>
            <td><%= app.type %></td>
            <td><%= app.port || '—' %></td>
            <td><span class="status status-stopped" data-role="status">stopped</span></td>
            <td><span data-role="latency" class="muted">—</span></td>
            <td><%= app.autostart ? 'sí' : 'no' %></td>
            <td><%= app.watchdog && app.watchdog.enabled ? app.watchdog.intervalMinutes + ' min' : 'off' %></td>
            <td class="actions">
              <button data-action="start" title="Iniciar">▶</button>
              <button data-action="stop" title="Parar">■</button>
              <button data-action="restart" title="Reiniciar">↻</button>
              <button data-action="pause" title="Pausar">⏸</button>
              <button data-action="resume" title="Reanudar">⏵</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/foot') %>
