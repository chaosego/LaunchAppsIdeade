{
  "settings": {
    "port": 4000,
    "watchdogDefaultIntervalMinutes": 150,
    "healthTimeoutMs": 5000,
    "statusPollIntervalMs": 10000
  },
  "apps": [
    {
      "id": "leroy-server",
      "name": "Servidor Leroy",
      "type": "node",
      "cwd": "T:/Servidores/leroy.server",
      "command": "npm",
      "args": ["run", "start"],
      "env": { "NODE_ENV": "production" },
      "port": 5001,
      "autostart": true,
      "health": {
        "http": { "url": "http://localhost:5001/numeracion/", "expectStatus": 200 },
        "tcp": { "port": 3000 },
        "latencyWarnMs": 2000,
        "command": { "run": "curl -fsS http://localhost:5001/numeracion", "timeoutMs": 4000 }
      },
      "watchdog": {
        "enabled": true,
        "intervalMinutes": 150,
        "restartOnUnhealthy": true
      }
    },
    {
      "id": "leroy-cliente",
      "name": "Cliente Leroy",
      "type": "next",
      "cwd": "T:/Servidores/leroy.cliente",
      "command": "npm",
      "args": ["run", "start --port=3000"],
      "port": 3000,
      "autostart": true,
      "health": {
        "tcp": { "port": 3000 },
        "http": { "url": "http://localhost:3000", "expectStatus": 200 },
        "latencyWarnMs": 3000
      },
      "watchdog": {
        "enabled": false
      }
    },
    {
      "id": "servidor-amazon",
      "name": "Servidor Amazon a Contasol",
      "type": "node",
      "cwd": "T:/Servidores/AMZ2FSOL.Server",
      "command": "npm",
      "args": ["run", "start"],
      "port": 5000,
      "autostart": true,
      "health": {
        "http": { "url": "http://localhost:5000/numeracion", "expectStatus": 200 },
        "tcp": { "port": 5000 },
        "latencyWarnMs": 2000,
        "command": { "run": "curl -fsS http://localhost:5000/numeracion", "timeoutMs": 4000 }
      },
      "watchdog": {
        "enabled": true,
        "intervalMinutes": 150,
        "restartOnUnhealthy": true
      }
    }
  ]
}
